# --- Data ---
# Directory holding the five input JSON files
NETZSIM_DATA_DIR=./data

# --- Grid catalog (importable grid models served by /grids) ---
# A committed dataset produced by the separate `gridgen` project (see
# data/DATASET.md). Point these at your own snapshot to override the bundled one.
NETZSIM_DING0_DIR=./data/ding0_grids
NETZSIM_GRID_LIBRARY=./data/grid_library.json

# --- LPG load library (cached household profiles served by /loadgen) ---
NETZSIM_LPG_LIBRARY_DIR=./data/lpg_library

# --- CORS (comma-separated origins; "*" allows any) ---
NETZSIM_CORS_ORIGINS=*

# --- Realtime clock (accelerated tick) ---
# Real seconds of wall-clock time per 1-minute simulation step.
# 1.0 => one step per second => a full 24h day simulated in 1440 seconds (24 min).
NETZSIM_STEP_INTERVAL_SECONDS=1.0
# Number of steps in one day (1440 = 24h at 1-min resolution)
NETZSIM_STEPS_PER_DAY=1440
# Start automatically on server boot
NETZSIM_AUTOSTART=true

# --- Engine ---
# How many past step-results to keep in memory for /history (1440 = one full day)
NETZSIM_HISTORY_SIZE=1440
# Warm-start each power flow from the previous solution (faster convergence)
NETZSIM_WARM_START=true

# --- API ---
NETZSIM_HOST=0.0.0.0
NETZSIM_PORT=8000
NETZSIM_LOG_LEVEL=info
