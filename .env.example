# --- Data ---
# Directory holding the five input JSON files
NETZSIM_DATA_DIR=./data

# --- Grid catalog (importable grid models served by /grids) ---
# A committed dataset produced by the separate `gridgen` project (see
# data/DATASET.md). Point these at your own snapshot to override the bundled one.
NETZSIM_DING0_DIR=./data/ding0_grids
NETZSIM_GRID_LIBRARY=./data/grid_library.json

# --- LPG load library (cached household profiles served by /loadgen) ---
NETZSIM_LPG_LIBRARY_DIR=./data/lpg_library

# --- CORS (comma-separated origins; "*" allows any) ---
NETZSIM_CORS_ORIGINS=*

# --- Realtime clock (accelerated tick) ---
# Real seconds of wall-clock time per 1-minute simulation step.
# 1.0 => one step per second => a full 24h day simulated in 1440 seconds (24 min).
NETZSIM_STEP_INTERVAL_SECONDS=1.0
# Number of steps in one day (1440 = 24h at 1-min resolution)
NETZSIM_STEPS_PER_DAY=1440
# Start automatically on server boot
NETZSIM_AUTOSTART=true

# --- Engine ---
# How many past step-results to keep in memory for /history (1440 = one full day)
NETZSIM_HISTORY_SIZE=1440
# Warm-start each power flow from the previous solution (faster convergence)
NETZSIM_WARM_START=true

# --- Observability ---
# When true (default), the live /state + /ws stream carries BOTH the observed
# measurement projection AND the full ground-truth power flow (so the UI's
# "reveal ground truth" toggle and the InfluxDB collector work). Set to false to
# enforce strict observability: only readings at placed measurement devices leave
# the server; the true per-bus/line/trafo results never go on the wire.
NETZSIM_EXPOSE_GROUND_TRUTH=true

# --- Session recording (CSV export of live runs) ---
# Where recordings are written (one directory per recording, ZIP on download)
NETZSIM_RECORDINGS_DIR=./data/recordings
# true = continuous operation: record from startup on and start a fresh
# recording after every grid apply / scenario load. Default: opt-in via the
# API/UI (POST /recording/start).
NETZSIM_RECORD=false

# --- API ---
# Default binds loopback only (write/control endpoints, no auth). Set 0.0.0.0
# to expose on the network (Docker does this in docker-compose.yml).
NETZSIM_HOST=127.0.0.1
NETZSIM_PORT=8000
NETZSIM_LOG_LEVEL=info

# --- Parallel operation / ports ---
# Nothing is hard-wired to :8000/:5173: the dev launcher (start_netzsim.bat)
# starts probing at NETZSIM_PORT / NETZSIM_UI_PORT and moves to the next free
# port when a FOREIGN app (e.g. rtheatflow) already listens there — a running
# netzsim is recognized via /health ("app": "netzsim") and reused instead.
# The launcher exports the picked ports to both server windows, so the Vite
# proxy follows automatically. NOTE: Vite itself does NOT read this .env —
# for a manual `cd ui && npm run dev` set NETZSIM_PORT (or the full target,
# NETZSIM_BACKEND=http://127.0.0.1:8010) and NETZSIM_UI_PORT as SHELL
# environment variables instead.
#NETZSIM_UI_PORT=5173
# Host-side port mappings for `docker compose` (container ports stay fixed).
# Shift these to run a second compose stack in parallel on the same machine:
#NETZSIM_HOST_PORT=8000
#UI_HOST_PORT=8080
#INFLUX_HOST_PORT=8086
#GRAFANA_HOST_PORT=3000
